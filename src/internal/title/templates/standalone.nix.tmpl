# Generated by prelude setup.
#
# Standalone prelude.lib builders (no flake-parts). Call with your package
# set and the prelude flake input, e.g. in your flake.nix:
#
#   let ui = import ./prelude.nix { inherit pkgs prelude; }; in
#   pkgs.mkShell { packages = [ ui.motd ui.menu ]; shellHook = "motd"; }
#
# Builder fields mirror the flake-parts options (defaults from
# src/prelude/defaults.nix). Prefer the flake-parts module for the full
# commented option surface; this shape is the direct lib API.
#
{ pkgs, prelude }:
let
  shared = {
    theme = {{ nixString .Theme }};  # color theme for all components; default "phosphor"

    # Per-token overrides on top of the theme (null keeps the theme token).
    # Values: null | hex string | ANSI-256 index.
{{- range .PaletteTokens }}
    # palette.{{ . }} = null;
{{- end }}

    colorProfile = {{ nixString .ColorProfile }};  # "auto" | "truecolor" | "ansi256"; default "auto"

    project = {{ nixString .Project }};  # shown in the MOTD banner and menu header; default "devshell"
  };
{{- if .Commands }}
  commands = {
{{- range .Commands }}
{{ template "commandEntry" . }}
{{- end }}
  };
{{- else }}
  # Project commands keyed by public name. First colon infers the menu group.
  # commands.dev = {
  #   exec = "pnpm dev";
  #   description = "start the dev server";
  #   # motd = 100;  # show on MOTD Getting Started at this sort order
  # };
  commands = { };
{{- end }}
in
{
{{- if .Motd }}
  motd = prelude.lib.mkMotd
    { inherit (pkgs) lib writeText buildGoModule; }
    (shared // {
      title = {
        text = {{ .TitlePath }};
        align = "center";  # left|center|right; default "left"
        # style = "spine";  # wordmark when text is null: plain|spine|bracketed|label|inline|inverted
      };
      commandCatalog = commands;
      # commandGroupOrder = [ "develop" ];  # preferred group order
      # background = null;
      # windowBackground = null;
      # clearScreen = true;
      # align = "center";
      # width = "full";
      # maxWidth = 96;
      # fullscreen = false;
      # margin = { top = 10; };
      # padding = { };
      # header.tagline.text = "Dev Shell Activated";
      # description.text = "";
      # links = [ ];
      # env = [ ];
      # recipes = { };
    });

{{- else }}
  # MOTD disabled in the wizard; the rendered title is kept for later:
  # motd = prelude.lib.mkMotd { inherit (pkgs) lib writeText buildGoModule; }
  #   (shared // { title.text = {{ .TitlePath }}; commandCatalog = commands; });

{{- end }}
{{- if .Menu }}
{{- if .Commands }}
  menu = prelude.lib.mkMenu
    { inherit (pkgs) lib writeShellApplication writeText buildGoModule; }
    (shared // {
      inherit commands;
      # placeholder = "type to filter commands…";
      # height = 12;
      # execute = true;
      # width = "full";
      # maxWidth = 96;
      # groupOrder = [ "develop" ];
    });

{{- else }}
  # The menu needs at least one command: add entries to `commands`
  # above, then uncomment:
  # menu = prelude.lib.mkMenu
  #   { inherit (pkgs) lib writeShellApplication writeText buildGoModule; }
  #   (shared // { inherit commands; });

{{- end }}
{{- end }}
{{- if .Docs }}
  # Starter page written by setup; add more entries as docs grow.
  docs = prelude.lib.mkDocs
    { inherit (pkgs) lib writeText buildGoModule; }
    (shared // { pages = [ { text = ./docs/getting-started.md; } ]; });

{{- end }}
{{- if .Prompt }}
  # The themed starship prompt is only generated by the flake-parts
  # module (prelude.prompt.enable); there is no standalone builder yet.
{{- end }}
}
