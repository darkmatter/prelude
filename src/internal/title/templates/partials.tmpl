{{/* Shared partials for setup-generated Nix config. */}}

{{define "commandEntry"}}
{{ .Pad }}{{ .Key }} = {
{{- if .Exec }}
{{ .Pad }}  exec = {{ nixString .Exec }};  # defaults to the key suffix after the first colon
{{- else }}
{{ .Pad }}  # exec = {{ nixString .InferredExec }};  # defaults to the key suffix after the first colon
{{- end }}
{{- if .Description }}
{{ .Pad }}  description = {{ nixString .Description }};
{{- else }}
{{ .Pad }}  # description = "";
{{- end }}
{{ .Pad }}  # key = null;  # single-key accelerator (`menu <key>`)
{{ .Pad }}  # usage = null;  # usage form shown in menu details
{{ .Pad }}  # details = null;  # extended description before arg entry
{{ .Pad }}  # examples = [ ];  # worked example invocations
{{ .Pad }}  # args = [ ];  # arg-entry mode: { token, description?, required?, boolean?, options? }
{{ .Pad }}  # invocation = null;  # canonical shell text for duplicate detection; defaults to exec
{{- if .MotdOrder }}
{{ .Pad }}  motd = {{ .MotdOrder }};  # MOTD Getting Started sort order; null hides from MOTD
{{- else }}
{{ .Pad }}  # motd = null;  # MOTD Getting Started sort order; null hides from MOTD
{{- end }}
{{ .Pad }}};
{{- end }}

{{/* Example command fields when the catalogue is empty (already under `# ` lines). */}}
{{define "commandFieldsCommented"}}
    #     # key = null;  # single-key accelerator (`menu <key>`)
    #     # usage = null;  # usage form shown in menu details
    #     # details = null;  # extended description before arg entry
    #     # examples = [ ];  # worked example invocations
    #     # args = [ ];  # arg-entry mode: { token, description?, required?, boolean?, options? }
    #     # invocation = null;  # canonical shell text for duplicate detection; defaults to exec
    #     # motd = null;  # MOTD Getting Started sort order; null hides from MOTD
{{- end }}

{{/* Full motd = { … }; block (no leading indent). Used active or via commentLines. */}}
{{define "motdBlock"}}
motd = {
  enable = true;

{{ template "motdOptions" . -}}
};
{{- end }}

