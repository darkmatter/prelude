# Generated by prelude setup.
#
# A flake-parts module: import it next to Prelude's module, e.g.
#
#   imports = [ prelude.flakeModules.default ./prelude.nix ];
#
# Every supported option is listed below. Values you chose in the wizard are
# active; everything else is commented at its default so you can see and
# enable options without leaving this file. Full prose reference:
# docs/reference/options.md (regenerated by docs-sync).
#
{ ... }:
{
  prelude = {
    theme = {{ nixString .Theme }};  # color theme for all components; default "phosphor"

    # Per-token overrides on top of the theme (null keeps the theme token).
    # Values: null | hex string | ANSI-256 index.
{{- range .PaletteTokens }}
    # palette.{{ . }} = null;
{{- end }}

    colorProfile = {{ nixString .ColorProfile }};  # "auto" | "truecolor" | "ansi256"; default "auto"

    project = {{ nixString .Project }};  # shown in the MOTD banner and menu header; default "devshell"

    # Project commands keyed by public `x` name. The first colon infers the
    # menu group; the complete key stays callable (e.g. `x db:migrate`).
{{- if .Commands }}
    commands = {
{{- range .Commands }}
{{ template "commandEntry" . }}
{{- end }}
    };
{{- else }}
    # commands = {
    #   dev = {
    #     exec = "pnpm dev";  # defaults to the key suffix after the first colon
    #     description = "start the dev server";
{{ template "commandFieldsCommented" }}
    #   };
    # };
    commands = { };
{{- end }}

{{- if .Motd }}

    # Static devshell welcome banner.
    motd = {
      enable = true;

{{ template "motdOptions" . }}
    };
{{- else }}

    # Static devshell welcome banner. Disabled in the wizard — uncomment to
    # enable with the rendered title:
{{ indent 4 (commentLines (include "motdBlock" .)) }}
    motd.enable = false;
{{- end }}

    # Interactive command picker (bubbletea TUI).
    menu = {
      enable = {{ bool .Menu }};
      # placeholder = "type to filter commands…";  # filter input hint
      # height = 12;  # filter list height in rows
      # execute = true;  # false prints the selected command instead of running it
      # width = "full";  # content width or "full"
      # maxWidth = 96;
    };

    # Themed starship config (`packages.prompt` = starship.toml).
    prompt = {
      enable = {{ bool .Prompt }};
      # settings = { };  # merged over themed defaults; see https://starship.rs/config/
      #   # add_newline = true;
      #   # format = "$directory$git_branch$character";
      # configFile = null;  # use this starship.toml verbatim instead of generating one
    };

    # Markdown pages in the navigable docs viewer. Each file becomes one
    # CONTENTS sidebar entry; digits 1–9 jump between pages. The first
    # level-one heading labels the entry.
{{- if .Docs }}
    # Starter page written by setup; add more entries as docs grow.
    docs.pages = [ { text = ./docs/getting-started.md; } ];
{{- else }}
    # docs.pages = [
    #   { text = ./docs/getting-started.md; }
    #   # Or split one file into H2 leaves (bind the flake's lib):
    #   # (inputs.prelude.lib.mdSplit ./README.md)
    # ];
    docs.pages = [ ];
{{- end }}

    # Preferred command-group order. Groups omitted follow alphabetically;
    # the built-in "prelude" group (menu/docs) stays first.
    # sort.groups = [ "develop" ];
  };
}
